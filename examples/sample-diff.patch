+import type { Report } from './report-service.js';
+
+const SPECIAL = /[",\n\r]/;
+
+function escapeField(value: unknown): string {
+  if (value === null || value === undefined) return '';
+  const str = typeof value === 'string' ? value : JSON.stringify(value);
+  if (SPECIAL.test(str)) {
+    return `"${str.replace(/"/g, '""')}"`;
+  }
+  return str;
+}
+
+export function renderCsv(report: Report): string {
+  const headers = report.rows[0] ? Object.keys(report.rows[0]) : [];
+  const lines: string[] = [];
+  lines.push(headers.map(escapeField).join(','));
+  for (const row of report.rows) {
+    lines.push(headers.map((h) => escapeField(row[h])).join(','));
+  }
+  return lines.join('\n');
+}
+
+export function streamCsv(report: Report): AsyncIterable<string> {
+  const headers = report.rows[0] ? Object.keys(report.rows[0]) : [];
+  yield headers.map(escapeField).join(',') + '\n';
+  for (const row of report.rows) {
+    yield headers.map((h) => escapeField(row[h])).join(',') + '\n';
+  }
+}
