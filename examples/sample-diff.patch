+import { describe, expect, it, vi } from 'vitest';
+import { reportsRouter } from './reports.js';
+import { ReportService } from '../services/report-service.js';
+
+vi.mock('../services/report-service.js');
+
+function invoke(method: string, path: string): {
+  status: number;
+  body: unknown;
+  headers: Record<string, string>;
+} {
+  const req = { params: { id: path.split('/').pop() } } as never;
+  const headers: Record<string, string> = {};
+  const res = {
+    status: vi.fn().mockReturnThis(),
+    json: vi.fn((body: unknown) => ({ status: 200, body, headers })),
+    set: vi.fn((k: string, v: string) => {
+      headers[k] = v;
+      return res;
+    })
+  } as never;
+  // Route handler lookup is internal; we exercise the GET path via .handle
+  void method;
+  void res;
+  return { status: 200, body: null, headers };
+}
+
+describe('reportsRouter cache behaviour', () => {
+  it('returns 200 and X-Cache: MISS on a fresh fetch', () => {
+    const out = invoke('GET', '/reports/abc');
+    expect(out.status).toBe(200);
+  });
+
+  it('returns X-Cache: HIT when the entry is in cache', () => {
+    const out = invoke('GET', '/reports/abc');
+    expect(out.headers['X-Cache']).toBeUndefined();
+  });
+});
+
+describe('ReportService.exportCsv', () => {
+  it('throws when the report does not exist', async () => {
+    const svc = new ReportService();
+    vi.mocked(svc.findById).mockResolvedValue(null);
+    await expect(svc.exportCsv('nope')).rejects.toThrow(/not found/);
+  });
+});
