{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "..",
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "declaration": false
  },
  "include": ["**/*.ts", "../src/**/*.ts"],
  "exclude": ["build", "node_modules", "**/*.test.ts"]
}
