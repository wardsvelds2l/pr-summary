node_modules/
lib/
coverage/
scripts/build/
*.log
.DS_Store
.env
.env.*
!.env.example
.vscode/
.idea/
*.tsbuildinfo
# Defensive: stray compiled JS/TS inside src/ would shadow the source for
# vite/vitest and silently break tests. The build script (tsconfig.build.json)
# emits to lib/, never src/, but if a contributor changes that, the .gitignore
# catches it.
src/*.js
src/*.js.map
# dist/ is intentionally NOT ignored — GitHub Actions requires the bundled
# dist/index.js to be present at the tagged commit. See CONTRIBUTING.md.
